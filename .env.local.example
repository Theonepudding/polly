# ── Discord Application ────────────────────────────────────────────────────────
# 1. Go to https://discord.com/developers/applications → New Application → name it "Polly"
# 2. OAuth2 tab → Redirects → add:
#      http://localhost:3000/api/auth/callback/discord
#      https://yourdomain.com/api/auth/callback/discord
# 3. Bot tab → Reset Token → copy the Bot Token below
# 4. Privileged Gateway Intents → enable: Server Members Intent, Message Content Intent
# 5. General Information → copy the Public Key below

DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DISCORD_BOT_TOKEN=your_bot_token_here

# Used on the invite buttons — same as DISCORD_CLIENT_ID, exposed to the browser
NEXT_PUBLIC_DISCORD_CLIENT_ID=your_client_id_here

# Ed25519 public key for verifying Discord interaction signatures
# Found at: Discord Developer Portal → Your App → General Information → Public Key
# Set Interactions Endpoint URL there to: https://yourdomain.com/api/discord/interactions
DISCORD_PUBLIC_KEY=your_public_key_here

# ── NextAuth ───────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=generate_a_random_secret_here
NEXTAUTH_URL=http://localhost:3000

# ── Bot Admins ──────────────────────────────────────────────────────────────────
# Comma-separated Discord user IDs that get super-admin access to /admin
BOT_ADMIN_USER_IDS=146783070047961088

# ── Cron protection ────────────────────────────────────────────────────────────
# Optional — if set, POST /api/cron/polls requires Authorization: Bearer <value>
# CRON_SECRET=your_cron_secret_here

# ── Cloudflare ─────────────────────────────────────────────────────────────────
# For production on Cloudflare Pages, set all the above in the Cloudflare dashboard
# (Settings → Environment Variables) — do NOT commit your real .env.local to git.
# Also create a KV namespace named POLLY_KV and paste its ID in wrangler.toml.
